POSTGRES_USER=forge
POSTGRES_PASSWORD=forge
POSTGRES_DB=forge

DATABASE_URL=postgresql+psycopg://forge:forge@localhost:5432/forge
REDIS_URL=redis://localhost:6379/0

FEATURE_OOBABOOGA=false
DEFAULT_INFERENCE_BACKEND=vllm
DEFAULT_INFERENCE_BASE_URL=http://localhost:8001/v1
DEFAULT_INFERENCE_API_KEY=local-key
VLLM_MODEL_ID=Qwen/Qwen2.5-Coder-7B-Instruct
GGUF_MODEL_FILE=models/qwen3_6/Qwen3-6B-Instruct-Q4_K_M.gguf

# Keeps Forge from using non-local inference endpoints.
ALL_LOCAL_MODE=true

# Optional offline cache settings (set to 1 to block network fetches for HF/Transformers).
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

FORGE_API_PORT=8000
FORGE_WEB_PORT=3000
